"""
Ganesh Mills 2026 Catalog ETL (All Sheets -> CSV)

Usage:
  python ganesh_2026_etl.py --input "C:\path\Ganesh Mills Price Catalog Effective February 2nd, 2026 in Excel.xlsx" \
                            --output "C:\path\GaneshETL_2026.csv"

Optional:
  --sheets "Signature Towel Collection,Tablelinen Collection"
  --log-level DEBUG
"""

from __future__ import annotations

import argparse
import logging
import re
from pathlib import Path
from typing import Dict, List, Optional, Tuple

import pandas as pd

LOG = logging.getLogger("ganesh_etl")

# Parent attribute keys appear in the *Description* column as "Quality:", "Specs:", etc.
PARENT_ATTR_KEYS = ("Quality", "Specs", "Color", "Description")
PARENT_ATTR_PATTERN = re.compile(
    r"^\s*(" + "|".join(PARENT_ATTR_KEYS) + r")\s*:\s*(.*)\s*$",
    re.IGNORECASE,
)

# Parent "item no" rows look like ALL CAPS text (no digits), e.g. "OXFORD CLASSIC/ BRONZE TOWEL COLLECTION"
def is_parent_sku(item_no: str) -> bool:
    s = item_no.strip()
    if not s:
        return False
    if any(ch.isdigit() for ch in s):
        return False
    return s == s.upper()  # all caps


def normalize(x) -> str:
    if pd.isna(x):
        return ""
    return str(x).strip()


def norm_col_name(c: str) -> str:
    # collapse massive whitespace and lowercase
    return re.sub(r"\s+", " ", str(c)).strip().lower()


def find_col(cols, desired: str) -> Optional[str]:
    """
    Find a column by comparing normalized names.
    Also supports prefix match (because the file has "2026 Description").
    """
    desired_norm = norm_col_name(desired)

    # exact normalized match
    for c in cols:
        if norm_col_name(c) == desired_norm:
            return c

    # prefix match
    for c in cols:
        if norm_col_name(c).startswith(desired_norm):
            return c

    return None


def parse_dims(dims_raw) -> Tuple[str, str, str]:
    """
    Parse Dims LxWxH, allowing 'x', 'X', '×', spaces, empty, or '0'
    Returns strings (L, W, H).
    """
    s = normalize(dims_raw)
    if not s or s == "0":
        return "", "", ""

    s = s.replace("×", "x").replace("X", "x")
    parts = [p.strip() for p in s.split("x") if p.strip()]
    parts = (parts + ["", "", ""])[:3]
    return parts[0], parts[1], parts[2]


def parse_case_qty(case_qty_raw) -> Tuple[str, str]:
    """
    Parse Case Qty into (Quantity, UOM)
    Examples: "50 DZ" -> ("50","DZ"), "Each" -> ("","Each"), 36 -> ("36","")
    """
    s = normalize(case_qty_raw)
    if not s:
        return "", ""

    if re.fullmatch(r"[-+]?\d+(\.\d+)?", s):
        return s, ""

    parts = s.split(None, 1)
    if len(parts) == 1:
        return "", parts[0]
    return parts[0], parts[1]


def process_sheet(sheet_name: str, df: pd.DataFrame) -> List[Dict]:
    cols = df.columns

    item_col = find_col(cols, "Ganesh Mills Item No.")
    desc_col = find_col(cols, "2026 Description") or find_col(cols, "Description")
    size_col = find_col(cols, "Size")
    weight_col = find_col(cols, "Weight")
    price_col = find_col(cols, "Special Price")
    unit_col = find_col(cols, "Unit")
    case_qty_col = find_col(cols, "Case Qty")
    bale_col = find_col(cols, "Bale / Carton")
    dims_col = find_col(cols, "Dims LxWxH")
    wtctn_col = find_col(cols, "Wt/Ctn")
    upc_col = find_col(cols, "UPC")

    if not item_col or not desc_col or not size_col:
        LOG.warning("Sheet '%s': missing key columns; skipping. Found item=%s desc=%s size=%s",
                    sheet_name, bool(item_col), bool(desc_col), bool(size_col))
        return []

    current_parent = ""
    parent_attrs: Dict[str, str] = {}
    out: List[Dict] = []

    for _, row in df.iterrows():
        item_no = normalize(row.get(item_col))
        desc_val = normalize(row.get(desc_col))
        size_val = normalize(row.get(size_col))

        # Parent row
        if is_parent_sku(item_no):
            current_parent = item_no
            parent_attrs = {}
            continue

        # Parent attribute row (Quality/Specs/Color/Description)
        m = PARENT_ATTR_PATTERN.match(desc_val) if desc_val else None
        if m:
            key = m.group(1).strip().title()  # Quality/Specs/Color/Description
            after_colon = normalize(m.group(2))
            # In this 2026 file, the actual value is typically in the Size column on that row
            from_size = size_val

            value = after_colon or from_size
            if after_colon and from_size and from_size != after_colon:
                value = f"{after_colon} | {from_size}"

            # IMPORTANT: prefix to avoid clobbering the child "Description" column
            parent_attrs[f"Parent {key}"] = value
            continue

        # Child SKU row: has a Size
        if size_val:
            L, W, H = parse_dims(row.get(dims_col)) if dims_col else ("", "", "")
            qty, uom = parse_case_qty(row.get(case_qty_col)) if case_qty_col else ("", "")

            out.append({
                "Sheet": sheet_name,
                "Parent Product": current_parent,
                "Ganesh Mills Item No.": item_no,
                "Description": desc_val,     # <-- keeps "Washcloth", etc.
                "Size": size_val,
                "Weight": row.get(weight_col) if weight_col else "",
                "Special Price": row.get(price_col) if price_col else "",
                "Unit": row.get(unit_col) if unit_col else "",
                "Quantity": qty,
                "UOM": uom,
                "Bale / Carton": row.get(bale_col) if bale_col else "",
                "Case Length": L,
                "Case Width": W,
                "Case Height": H,
                "Wt/Ctn": row.get(wtctn_col) if wtctn_col else "",
                "UPC": row.get(upc_col) if upc_col else "",
                **parent_attrs
            })

    return out


def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(description="Ganesh Mills 2026 Excel -> CSV ETL")
    p.add_argument("--input", required=True, help="Path to the Ganesh Mills 2026 .xlsx file")
    p.add_argument("--output", required=True, help="Path to output CSV")
    p.add_argument("--sheets", default="", help="Optional comma-separated list of sheet names to process")
    p.add_argument("--log-level", default="INFO", help="DEBUG, INFO, WARNING, ERROR")
    return p.parse_args()


def main() -> None:
    args = parse_args()
    logging.basicConfig(
        level=getattr(logging, args.log_level.upper(), logging.INFO),
        format="%(levelname)s: %(message)s"
    )

    in_path = Path(args.input).expanduser()
    out_path = Path(args.output).expanduser()
    out_path.parent.mkdir(parents=True, exist_ok=True)

    if not in_path.exists():
        raise FileNotFoundError(f"Input Excel file not found: {in_path}")

    sheet_filter = [s.strip() for s in args.sheets.split(",") if s.strip()]

    xl = pd.ExcelFile(in_path, engine="openpyxl")
    all_rows: List[Dict] = []

    for sheet_name in xl.sheet_names:
        if sheet_filter and sheet_name not in sheet_filter:
            continue
        df = pd.read_excel(in_path, sheet_name=sheet_name, engine="openpyxl")
        LOG.info("Processing sheet: %s (%d rows)", sheet_name, len(df))
        all_rows.extend(process_sheet(sheet_name, df))

    out_df = pd.DataFrame(all_rows)

    if out_df.empty:
        LOG.warning("No output rows produced. Check the workbook structure.")
        return

    # Quantity numeric when possible
    out_df["Quantity"] = pd.to_numeric(out_df.get("Quantity"), errors="coerce")

    out_df.to_csv(out_path, index=False)
    LOG.info("Wrote %d rows -> %s", len(out_df), out_path)


if __name__ == "__main__":
    main()
