FLASK_ENV=production
ENABLE_SCHEDULER=0
FULCRUM_RUN_EMBEDDED_SCHEDULER=0
FULCRUM_APP_BASE_URL=https://fulcrum.fulcrumagentics.com
FULCRUM_AUTH_CALLBACK_URL=https://fulcrum.fulcrumagentics.com/fulcrum/auth
FULCRUM_LOAD_CALLBACK_URL=https://fulcrum.fulcrumagentics.com/fulcrum/load
FULCRUM_UNINSTALL_CALLBACK_URL=https://fulcrum.fulcrumagentics.com/fulcrum/uninstall
FULCRUM_REMOVE_USER_CALLBACK_URL=https://fulcrum.fulcrumagentics.com/fulcrum/remove-user
FULCRUM_GSC_OAUTH_CALLBACK_URL=https://fulcrum.fulcrumagentics.com/fulcrum/integrations/gsc/callback
FULCRUM_GA4_OAUTH_CALLBACK_URL=https://fulcrum.fulcrumagentics.com/fulcrum/integrations/ga4/callback
FULCRUM_PRIVACY_POLICY_URL=https://fulcrum.fulcrumagentics.com/fulcrum/privacy
